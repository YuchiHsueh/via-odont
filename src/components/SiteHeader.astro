---
import { site, waUrl } from "../data/site";

const nav = [
	{ href: "#inicio", label: "Inicio" },
	{ href: "#filosofia", label: "Filosofía" },
	{ href: "#especialidades", label: "Especialidades" },
	{ href: "#equipo", label: "Profesionales" },
	{ href: "#tratamientos", label: "Tratamientos" },
	{ href: "#instalaciones", label: "Instalaciones" },
	{ href: "#ubicacion", label: "Ubicación" },
	{ href: "#contacto", label: "Contacto" },
];
---

<header class="header" id="top">
	<div class="header__inner container">
		<a class="header__brand" href="#inicio" aria-label={`${site.name} — inicio`}>
			<span class="header__name display">{site.name}</span>
			<span class="header__sub">odontología integral</span>
		</a>

		<button
			type="button"
			class="header__burger"
			id="nav-toggle"
			aria-label="Abrir menú"
			aria-expanded="false"
			aria-controls="nav-panel"
		>
			<span class="header__burger-line" aria-hidden="true"></span>
			<span class="header__burger-line" aria-hidden="true"></span>
			<span class="header__burger-line" aria-hidden="true"></span>
		</button>

		<div class="header__backdrop" id="nav-backdrop" hidden aria-hidden="true"></div>

		<div class="header__panel" id="nav-panel">
			<nav class="header__nav" aria-label="Principal">
				<ul class="header__nav-list">
					{
						nav.map((item) => (
							<li>
								<a class="header__nav-link" href={item.href} data-nav-link>
									{item.label}
								</a>
							</li>
						))
					}
				</ul>
			</nav>
			<div class="header__panel-actions">
				<a class="btn btn--ghost header__wa" href={waUrl} target="_blank" rel="noopener noreferrer">
					WhatsApp
				</a>
				<a class="btn btn--primary header__cta" href="#contacto" data-nav-link>Reservar turno</a>
			</div>
		</div>
	</div>
</header>

<script>
	(() => {
		const toggle = document.getElementById("nav-toggle");
		const panel = document.getElementById("nav-panel");
		const backdrop = document.getElementById("nav-backdrop");
		if (!toggle || !panel || !backdrop) return;

		const links = panel.querySelectorAll("[data-nav-link]");

		function setOpen(open) {
			toggle.setAttribute("aria-expanded", String(open));
			toggle.setAttribute("aria-label", open ? "Cerrar menú" : "Abrir menú");
			panel.classList.toggle("is-open", open);
			backdrop.classList.toggle("is-open", open);
			backdrop.toggleAttribute("hidden", !open);
			document.body.classList.toggle("nav-open", open);
		}

		function close() {
			setOpen(false);
		}

		toggle.addEventListener("click", () => {
			const open = !panel.classList.contains("is-open");
			setOpen(open);
		});

		backdrop.addEventListener("click", close);

		links.forEach((a) => a.addEventListener("click", close));

		document.addEventListener("keydown", (e) => {
			if (e.key === "Escape") close();
		});
	})();
</script>

<style>
	.header {
		position: sticky;
		top: 0;
		z-index: 80;
		background: color-mix(in srgb, var(--cream) 92%, transparent);
		backdrop-filter: blur(12px);
		border-bottom: 1px solid color-mix(in srgb, var(--line) 55%, transparent);
	}

	.header__inner {
		display: grid;
		grid-template-columns: 1fr auto auto;
		align-items: center;
		gap: 1rem 1.25rem;
		padding-block: 1rem;
	}

	.header__brand {
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
		text-decoration: none;
		color: inherit;
		justify-self: start;
	}

	.header__brand:hover {
		color: inherit;
	}

	.header__name {
		font-size: clamp(1.2rem, 2.2vw, 1.65rem);
		line-height: 1.1;
		letter-spacing: 0.04em;
	}

	.header__sub {
		font-size: 0.65rem;
		text-transform: uppercase;
		letter-spacing: 0.18em;
		color: var(--sage-mid);
	}

	.header__burger {
		display: none;
		flex-direction: column;
		justify-content: center;
		gap: 5px;
		width: 2.75rem;
		height: 2.75rem;
		padding: 0;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: var(--cream);
		cursor: pointer;
		justify-self: end;
		grid-column: 2;
	}

	.header__burger-line {
		display: block;
		width: 1.15rem;
		height: 2px;
		margin-inline: auto;
		background: var(--ink-deep);
		border-radius: 1px;
		transition:
			transform 0.25s var(--ease-out),
			opacity 0.2s;
	}

	.header__burger[aria-expanded="true"] .header__burger-line:nth-child(1) {
		transform: translateY(7px) rotate(45deg);
	}

	.header__burger[aria-expanded="true"] .header__burger-line:nth-child(2) {
		opacity: 0;
	}

	.header__burger[aria-expanded="true"] .header__burger-line:nth-child(3) {
		transform: translateY(-7px) rotate(-45deg);
	}

	.header__backdrop {
		display: none;
	}

	.header__panel {
		display: contents;
	}

	.header__nav-list {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 1rem 1.5rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.header__nav-link {
		font-size: 0.82rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		text-decoration: none;
		color: var(--ink);
	}

	.header__nav-link:hover {
		color: var(--sage-mid);
	}

	.header__panel-actions {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		flex-wrap: wrap;
	}

	.header__cta {
		white-space: nowrap;
	}

	.header__wa {
		white-space: nowrap;
	}

	@media (min-width: 901px) {
		.header__inner {
			grid-template-columns: auto 1fr auto;
		}

		.header__brand {
			grid-column: 1;
		}

		.header__burger {
			display: none !important;
		}

		.header__panel {
			grid-column: 2 / -1;
			display: flex;
			align-items: center;
			justify-content: flex-end;
			gap: 1.5rem;
		}

		.header__nav {
			margin-inline-end: auto;
		}

		.header__nav-list {
			justify-content: flex-end;
		}

		.header__panel-actions {
			flex-shrink: 0;
		}
	}

	@media (max-width: 900px) {
		.header__inner {
			grid-template-columns: 1fr auto;
			grid-template-rows: auto auto;
		}

		.header__brand {
			grid-column: 1;
			grid-row: 1;
		}

		.header__burger {
			display: flex;
			grid-column: 2;
			grid-row: 1;
		}

		.header__backdrop {
			display: block;
			position: fixed;
			inset: 0;
			z-index: 78;
			background: color-mix(in srgb, var(--ink-deep) 45%, transparent);
			opacity: 0;
			pointer-events: none;
			transition: opacity 0.28s var(--ease-out);
		}

		.header__backdrop.is-open {
			opacity: 1;
			pointer-events: auto;
		}

		.header__panel {
			display: flex;
			flex-direction: column;
			gap: 1.75rem;
			position: fixed;
			z-index: 79;
			top: 0;
			right: 0;
			width: min(20rem, 88vw);
			height: 100vh;
			height: 100dvh;
			padding: 5.5rem 1.5rem 2rem;
			background: var(--cream);
			border-left: 1px solid var(--line);
			box-shadow: -12px 0 40px color-mix(in srgb, var(--ink) 12%, transparent);
			transform: translateX(100%);
			transition: transform 0.3s var(--ease-out);
			pointer-events: none;
			grid-column: 1 / -1;
			grid-row: 2;
		}

		.header__panel.is-open {
			transform: translateX(0);
			pointer-events: auto;
		}

		.header__nav-list {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.25rem;
		}

		.header__nav-link {
			display: block;
			padding: 0.65rem 0;
			font-size: 0.95rem;
		}

		.header__panel-actions {
			flex-direction: column;
			align-items: stretch;
			margin-top: auto;
			padding-top: 1rem;
			border-top: 1px solid var(--line);
		}

		.header__panel-actions .btn {
			width: 100%;
			text-align: center;
		}
	}
</style>
