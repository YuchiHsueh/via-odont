---
import "../styles/global.css";
import { site } from "../data/site";
import {
	seo,
	buildDentistJsonLd,
	getSiteOrigin,
	getCanonicalUrl,
	absoluteAssetUrl,
} from "../data/seo";

interface Props {
	title?: string;
	description?: string;
	shareImage?: string;
}

const {
	title = seo.title,
	description = seo.description,
	shareImage = seo.shareImage,
} = Astro.props;

const basePath = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const origin = getSiteOrigin(Astro.site, Astro.url.origin);
const canonical = getCanonicalUrl(origin, import.meta.env.BASE_URL);
const ogImage = absoluteAssetUrl(origin, import.meta.env.BASE_URL, shareImage);
const jsonLd = buildDentistJsonLd(origin, import.meta.env.BASE_URL);
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#f8f7f2" />
		<title>{title}</title>
		<link rel="canonical" href={canonical} />
		<link rel="icon" type="image/svg+xml" href={`${basePath}img/logo_no_text.svg`} />
		<link rel="apple-touch-icon" href={`${basePath}img/logo_no_text.svg`} />

		<meta property="og:type" content="website" />
		<meta property="og:locale" content={seo.locale} />
		<meta property="og:site_name" content={site.name} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta property="og:image" content={ogImage} />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />

		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Nunito+Sans:ital,opsz,wght@0,6..12,300..700;1,6..12,300..700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<slot />
	</body>
</html>
