---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import WhatsAppFloat from "../components/WhatsAppFloat.astro";
import TreatmentAccordion from "../components/TreatmentAccordion.astro";
import InstalacionesCarousel from "../components/InstalacionesCarousel.astro";
import { site, waUrl } from "../data/site";
import {
	professionals,
	treatmentIntro,
	treatmentBlocks,
} from "../data/content";

const basePath = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const img = (filename: string) => `${basePath}img/${encodeURIComponent(filename)}`;

const heroImage = img("foto 2.jpeg");

const instalacionesSlides = [
	"consul.jpeg",
	"consul2.jpeg",
	"consul4.jpeg",
	"consul5.jpeg",
	"consul6.jpeg",
	"consul7.jpeg",
	"consul8.jpeg",
].map(img);

const professionalsResolved = professionals.map((p) => ({
	...p,
	imageUrl: p.photo ? img(p.photo) : null,
}));

const treatmentBlocksResolved = treatmentBlocks.map((block) => ({
	...block,
	iconUrl: img(block.icon),
}));
---

<BaseLayout>
	<SiteHeader />
	<WhatsAppFloat />
	<main>
		<section class="hero" id="inicio" aria-labelledby="hero-heading">
			<div class="hero__media">
				<img
					class="hero__img"
					src={heroImage}
					width="1600"
					height="1067"
					alt={`${site.name} — consultorio dental en Cucha Cucha, CABA`}
					loading="eager"
					fetchpriority="high"
					decoding="async"
				/>
				<div class="hero__veil" aria-hidden="true"></div>
			</div>
			<div class="hero__content container">
				<p class="section-label animate-in">Salud integral · Estética natural</p>
				<h1 id="hero-heading" class="display hero__title animate-in delay-1">
					{site.name}
				</h1>
				<p class="lede hero__lede animate-in delay-2">
					{site.tagline}
				</p>
				<p class="hero__location animate-in delay-2">{site.addressLine}</p>
				<div class="hero__actions animate-in delay-3">
					<a class="btn btn--ghost" href="#filosofia">Conocé nuestra filosofía</a>
				</div>
			</div>
		</section>

		<section class="band band--sage" id="filosofia" aria-labelledby="filosofia-heading">
			<div class="container filosofia">
				<h2 id="filosofia-heading" class="display filosofia__title">Filosofía de trabajo</h2>
				<p class="filosofia__intro">
					La prevención y la educación guían cada tratamiento. Creemos que una sonrisa armónica es
					consecuencia de un organismo sano.
				</p>

				<div class="filosofia__grid">
					<article class="filosofia__card">
						<h3 class="filosofia__card-title display">Misión</h3>
						<p>
							Nuestra misión es devolver la salud integral a la boca de nuestros pacientes mediante la
							prevención y la educación. Nos dedicamos a recuperar la función y la seguridad de cada
							persona, bajo la premisa de que una estética radiante es la consecuencia natural de un
							organismo sano. Nuestro compromiso es brindar al paciente las herramientas y el
							conocimiento necesarios para que sea el principal guardián de su propia salud.
						</p>
					</article>
					<article class="filosofia__card">
						<h3 class="filosofia__card-title display">Visión</h3>
						<p>
							Aspiramos a ser referentes en una odontología preservadora y ética, donde la prioridad sea
							mantener la estructura original y la esencia de quien nos elige. Buscamos evolucionar
							hacia una práctica que valore la integridad biológica.
						</p>
					</article>
					<article class="filosofia__card">
						<h3 class="filosofia__card-title display">Valores</h3>
						<p>
							Entendemos la odontología como un proceso que respeta la biología y sus tiempos naturales,
							por lo que la educación constante es nuestra mejor herramienta: guiamos al paciente en
							cada etapa para que aprenda sobre su tratamiento. Alcanzamos la excelencia mediante la
							precisión técnica y un compromiso ético que prioriza la salud desde la raíz.
						</p>
					</article>
				</div>
			</div>
		</section>

		<section class="band band--team" id="equipo" aria-labelledby="equipo-heading">
			<div class="container">
				<p class="section-label">Equipo</p>
				<h2 id="equipo-heading" class="display equipo__title">Profesionales</h2>
				<p class="equipo__lede">
					Especialistas que trabajan de forma coordinada para brindarte una atención integral.
				</p>
				<ul class="equipo__grid">
					{
						professionalsResolved.map((p) => (
							<li
								class:list={[
									"equipo-card",
									!p.imageUrl && "equipo-card--placeholder",
									p.featured && "equipo-card--featured",
								]}
							>
								<article class="equipo-card__inner">
									<div
										class:list={[
											"equipo-card__visual",
											!p.imageUrl && "equipo-card__visual--placeholder",
										]}
									>
										{
											p.imageUrl ? (
												<div class="equipo-card__media">
													<img
														class="equipo-card__img"
														src={p.imageUrl}
														alt={`Retrato profesional de ${p.name}`}
														width="640"
														height="800"
														loading="lazy"
														decoding="async"
														style={`--photo-zoom: ${p.photoZoom ?? 1.16}; --photo-focus: ${p.photoFocus ?? "center 22%"}; --photo-origin-y: ${p.photoOriginY ?? "17.5%"}`}
													/>
												</div>
											) : (
												<div class="equipo-card__ph-inner" aria-hidden="true">
													{p.initials && (
														<span class="equipo-card__initials display">{p.initials}</span>
													)}
												</div>
											)
										}
										<div
											class:list={[
												"equipo-card__scrim",
												!p.imageUrl && "equipo-card__scrim--placeholder",
											]}
											aria-hidden="true"
										/>
										<h3 class="equipo-card__nameplate display">
											<span class="equipo-card__nameplate-text">{p.name}</span>
										</h3>
									</div>
									<div class="equipo-card__body">
										<ul class="equipo-card__roles equipo-card__roles--fill">
											{p.roles.map((r) => (
												<li>
													<span class="equipo-card__role-pill">{r}</span>
												</li>
											))}
										</ul>
									</div>
								</article>
							</li>
						))
					}
				</ul>
			</div>
		</section>

		<section class="tratamientos" id="tratamientos" aria-labelledby="trat-heading">
			<div class="container">
				<p class="section-label">Tratamientos</p>
				<h2 id="trat-heading" class="display tratamientos__title">{treatmentIntro.title}</h2>
				<p class="tratamientos__lead">{treatmentIntro.lead}</p>

				<TreatmentAccordion blocks={treatmentBlocksResolved} />
			</div>
		</section>

		<section class="instalaciones" id="instalaciones" aria-labelledby="instalaciones-heading">
			<div class="container">
				<h2 id="instalaciones-heading" class="display instalaciones__title">Nuestras instalaciones</h2>
				<p class="instalaciones__lede">
					Espacios pensados para la calma, la higiene y el acompañamiento en cada visita.
				</p>
				<InstalacionesCarousel slides={instalacionesSlides} />
			</div>
		</section>

		<section class="ubicacion" id="ubicacion" aria-labelledby="ubicacion-heading">
			<div class="container">
				<h2 id="ubicacion-heading" class="display ubicacion__title">¿Dónde estamos?</h2>
				<p class="ubicacion__lede">
					Encontranos en <strong>{site.name}</strong>, {site.addressLine}. También podés llamarnos al{" "}
					<a href={site.phoneHref}>{site.phoneDisplay}</a> o escribirnos por WhatsApp. Podés ampliar el mapa o
					abrir la ruta en Google Maps desde el recuadro.
				</p>
				<div class="ubicacion__frame">
					<iframe
						src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3283.9679399829215!2d-58.45869275838438!3d-34.60497219797555!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x95bccbb7341fa0d3%3A0x83d93cf2e0ef9f53!2sVIA%20Odontolog%C3%ADa%20Integral!5e0!3m2!1ses!2sar!4v1778289413555!5m2!1ses!2sar"
						title="Ubicación de VIA Odontología Integral en Google Maps"
						width="600"
						height="450"
						loading="lazy"
						referrerpolicy="no-referrer-when-downgrade"
						allowfullscreen=""
					></iframe>
				</div>
			</div>
		</section>

		<section class="band band--cta">
			<div class="container cta">
				<h2 class="display cta__title">¿Querés coordinar una consulta?</h2>
				<p class="cta__text">
					Te respondemos por WhatsApp para agendar tu primera visita o resolver dudas sobre tratamientos.
				</p>
				<a class="btn btn--primary cta__btn" href={waUrl} target="_blank" rel="noopener noreferrer">
					Contactar por WhatsApp
				</a>
			</div>
		</section>
	</main>
	<SiteFooter />
</BaseLayout>

<style>
	.hero {
		position: relative;
		min-height: min(88vh, 900px);
		display: grid;
		align-items: end;
		color: var(--cream);
	}

	.hero__media {
		position: absolute;
		inset: 0;
		overflow: hidden;
	}

	.hero__img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transform: scale(1.02);
	}

	.hero__veil {
		position: absolute;
		inset: 0;
		background: linear-gradient(
			105deg,
			color-mix(in srgb, var(--ink-deep) 78%, transparent) 0%,
			color-mix(in srgb, var(--ink) 35%, transparent) 42%,
			color-mix(in srgb, var(--sage-mid) 25%, transparent) 100%
		);
	}

	.hero__content {
		position: relative;
		padding-block: clamp(3rem, 8vw, 5.5rem);
		max-width: 640px;
	}

	.hero .section-label {
		color: color-mix(in srgb, var(--cream) 75%, var(--sage));
	}

	.hero__title {
		font-size: clamp(2.5rem, 6vw, 3.75rem);
		line-height: 1.05;
		margin: 0 0 1rem;
		color: var(--cream);
		text-shadow: 0 2px 40px color-mix(in srgb, var(--ink-deep) 45%, transparent);
	}

	.hero__lede {
		color: color-mix(in srgb, var(--cream) 92%, white);
		margin: 0 0 0.75rem;
	}

	.hero__location {
		margin: 0 0 2rem;
		font-size: 0.92rem;
		line-height: 1.5;
		color: color-mix(in srgb, var(--cream) 78%, var(--sage));
		max-width: 36ch;
	}

	.hero__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
	}

	.hero .btn--primary {
		background: var(--cream);
		color: var(--ink-deep);
	}

	.hero .btn--primary:hover {
		background: var(--sage);
		color: var(--ink-deep);
	}

	.hero .btn--ghost {
		border-color: color-mix(in srgb, var(--cream) 55%, transparent);
		color: var(--cream);
	}

	.hero .btn--ghost:hover {
		background: color-mix(in srgb, var(--cream) 12%, transparent);
		border-color: var(--cream);
		color: var(--cream);
	}

	.band {
		padding-block: var(--space-section);
	}

	.band--sage {
		background: linear-gradient(
			180deg,
			color-mix(in srgb, var(--sage) 35%, var(--cream)) 0%,
			var(--cream) 100%
		);
		border-block: 1px solid color-mix(in srgb, var(--line) 45%, transparent);
	}

	.filosofia__title {
		font-size: clamp(2rem, 4vw, 2.75rem);
		margin: 0 0 1rem;
	}

	.filosofia__intro {
		font-size: 1.125rem;
		max-width: 52ch;
		margin: 0 0 2.75rem;
		color: var(--ink);
	}

	.filosofia__grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 2rem 2.5rem;
	}

	.filosofia__card {
		padding-top: 1.5rem;
		border-top: 1px solid color-mix(in srgb, var(--line) 70%, transparent);
	}

	.filosofia__card p {
		margin: 0;
		color: var(--ink);
	}

	.filosofia__card-title {
		font-size: 1.5rem;
		margin: 0 0 1rem;
	}

	@media (max-width: 720px) {
		.filosofia__grid {
			grid-template-columns: 1fr;
		}
	}

	.band--team {
		background: color-mix(in srgb, var(--sage) 22%, var(--cream));
		border-block: 1px solid color-mix(in srgb, var(--line) 50%, transparent);
	}

	.equipo__title {
		font-size: clamp(1.85rem, 3.5vw, 2.5rem);
		margin: 0 0 0.75rem;
	}

	.equipo__lede {
		margin: 0 0 2.25rem;
		max-width: 44ch;
	}

	.equipo__grid {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: clamp(1.25rem, 3vw, 2rem);
		align-items: stretch;
	}

	.equipo-card {
		display: flex;
		flex-direction: column;
		min-height: 0;
		height: 100%;
	}

	.equipo-card__inner {
		flex: 1;
		min-height: 0;
		display: flex;
		flex-direction: column;
		background: var(--cream);
		border-radius: 14px;
		overflow: hidden;
		border: 1px solid color-mix(in srgb, var(--line) 55%, transparent);
		box-shadow:
			0 1px 0 color-mix(in srgb, var(--cream) 80%, white) inset,
			0 18px 40px color-mix(in srgb, var(--ink-deep) 6%, transparent);
		transition:
			transform 0.35s var(--ease-out),
			box-shadow 0.35s var(--ease-out),
			border-color 0.25s var(--ease-out);
	}

	.equipo-card__inner:hover {
		transform: translateY(-4px);
		border-color: color-mix(in srgb, var(--sage-mid) 45%, var(--line));
		box-shadow:
			0 1px 0 color-mix(in srgb, var(--cream) 80%, white) inset,
			0 22px 48px color-mix(in srgb, var(--ink-deep) 10%, transparent);
	}

	.equipo-card--featured .equipo-card__inner {
		border-color: color-mix(in srgb, var(--sage-mid) 55%, var(--line));
		box-shadow:
			0 0 0 1px color-mix(in srgb, var(--sage) 40%, transparent),
			0 1px 0 color-mix(in srgb, var(--cream) 80%, white) inset,
			0 24px 56px color-mix(in srgb, var(--ink-deep) 12%, transparent);
	}

	.equipo-card--featured .equipo-card__inner:hover {
		box-shadow:
			0 0 0 1px color-mix(in srgb, var(--sage-mid) 35%, transparent),
			0 1px 0 color-mix(in srgb, var(--cream) 80%, white) inset,
			0 28px 64px color-mix(in srgb, var(--ink-deep) 14%, transparent);
	}

	.equipo-card__visual {
		position: relative;
		flex: 0 0 auto;
		width: 100%;
		aspect-ratio: 3 / 4;
		overflow: hidden;
		background: var(--line);
	}

	.equipo-card__visual--placeholder {
		background: color-mix(in srgb, var(--sage) 28%, var(--cream));
	}

	.equipo-card__media {
		position: absolute;
		inset: 0;
		overflow: hidden;
	}

	.equipo-card__img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: var(--photo-focus, center 22%);
		transform-origin: center var(--photo-origin-y, 17.5%);
		transform: scale(var(--photo-zoom, 1.16));
		transition: transform 0.55s var(--ease-out);
		will-change: transform;
	}

	.equipo-card__inner:hover .equipo-card__img {
		transform: scale(calc(var(--photo-zoom, 1.16) * 1.04));
	}

	.equipo-card__ph-inner {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		background:
			radial-gradient(ellipse 120% 80% at 20% 20%, color-mix(in srgb, var(--sage) 55%, transparent), transparent 55%),
			radial-gradient(ellipse 100% 70% at 85% 75%, color-mix(in srgb, var(--sage-mid) 22%, transparent), transparent 50%),
			linear-gradient(160deg, var(--cream) 0%, color-mix(in srgb, var(--sage) 35%, var(--cream)) 100%);
	}

	.equipo-card__initials {
		font-size: clamp(4.5rem, 18vw, 6.5rem);
		line-height: 1;
		letter-spacing: 0.06em;
		color: color-mix(in srgb, var(--ink-deep) 12%, var(--sage-mid));
		user-select: none;
	}

	.equipo-card__scrim {
		position: absolute;
		inset: 0;
		background: linear-gradient(
			to top,
			color-mix(in srgb, var(--ink-deep) 88%, transparent) 0%,
			color-mix(in srgb, var(--ink-deep) 35%, transparent) 38%,
			transparent 62%
		);
		pointer-events: none;
		z-index: 1;
	}

	.equipo-card__scrim--placeholder {
		background: linear-gradient(
			to top,
			color-mix(in srgb, var(--ink-deep) 72%, transparent) 0%,
			color-mix(in srgb, var(--ink-deep) 18%, transparent) 45%,
			transparent 70%
		);
	}

	.equipo-card__nameplate {
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0;
		z-index: 2;
		margin: 0;
		padding: 1.35rem 1.25rem 1.15rem;
		font-size: clamp(1.05rem, 2.8vw, 1.35rem);
		font-weight: 500;
		line-height: 1.2;
		color: var(--cream);
		text-shadow: 0 2px 24px color-mix(in srgb, var(--ink-deep) 55%, transparent);
	}

	.equipo-card--placeholder .equipo-card__nameplate {
		text-shadow: 0 2px 20px color-mix(in srgb, var(--ink-deep) 40%, transparent);
	}

	.equipo-card__nameplate-text {
		display: block;
		border-left: 3px solid color-mix(in srgb, var(--sage) 85%, transparent);
		padding-left: 0.75rem;
	}

	.equipo-card__body {
		padding: 1.25rem 1.35rem 1.5rem;
		flex: 1 1 auto;
		display: flex;
		flex-direction: column;
		min-height: 0;
	}

	.equipo-card__roles--fill {
		margin-top: auto;
	}

	.equipo-card__roles {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem 0.5rem;
		align-content: flex-end;
	}

	.equipo-card__roles li {
		margin: 0;
	}

	.equipo-card__role-pill {
		display: inline-block;
		padding: 0.4rem 0.75rem;
		font-size: 0.78rem;
		font-weight: 600;
		letter-spacing: 0.03em;
		line-height: 1.35;
		color: var(--ink-deep);
		background: color-mix(in srgb, var(--sage) 32%, var(--cream));
		border: 1px solid color-mix(in srgb, var(--line) 70%, transparent);
		border-radius: 6px;
	}

	@media (max-width: 640px) {
		.equipo__grid {
			grid-template-columns: 1fr;
		}
	}

	.tratamientos {
		padding-block: var(--space-section);
	}

	.tratamientos__title {
		font-size: clamp(1.85rem, 3.2vw, 2.35rem);
		margin: 0 0 0.75rem;
		max-width: none;
	}

	.tratamientos__lead {
		margin: 0 0 2.5rem;
		font-size: 1.08rem;
		max-width: none;
		line-height: 1.65;
	}

	.instalaciones {
		padding-bottom: var(--space-section);
	}

	.instalaciones__title {
		font-size: clamp(1.85rem, 3.5vw, 2.5rem);
		margin: 0 0 0.75rem;
	}

	.instalaciones__lede {
		margin: 0 0 2.5rem;
		max-width: 42ch;
	}

	.ubicacion {
		padding-bottom: var(--space-section);
		scroll-margin-top: 5.5rem;
	}

	.ubicacion__title {
		font-size: clamp(1.85rem, 3.5vw, 2.5rem);
		margin: 0 0 0.75rem;
	}

	.ubicacion__lede {
		margin: 0 0 1.75rem;
		max-width: 52ch;
		line-height: 1.6;
	}

	.ubicacion__frame {
		position: relative;
		width: 100%;
		max-width: 920px;
		margin-inline: auto;
		aspect-ratio: 4 / 3;
		max-height: min(70vh, 520px);
		border-radius: 14px;
		overflow: hidden;
		border: 1px solid color-mix(in srgb, var(--line) 70%, transparent);
		box-shadow: 0 16px 48px color-mix(in srgb, var(--ink-deep) 8%, transparent);
		background: var(--line);
	}

	.ubicacion__frame iframe {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		border: 0;
	}

	.band--cta {
		background: var(--sage);
		padding-block: clamp(3rem, 8vw, 4.5rem);
		text-align: center;
	}

	.cta__title {
		font-size: clamp(1.75rem, 3vw, 2.25rem);
		margin: 0 0 1rem;
	}

	.cta__text {
		margin: 0 auto 1.75rem;
		max-width: 46ch;
	}

	.cta__btn {
		background: var(--ink);
		color: var(--cream);
	}
</style>
